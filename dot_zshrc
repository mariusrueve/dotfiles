export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"
export COLORTERM="truecolor"
export TERM="xterm-256color"
export EDITOR="nvim"
export FZF_DEFAULT_COMMAND="fd --type f --strip-cwd-prefix --hidden --follow --exclude .git"
export PATH="$HOME/.local/bin:$PATH"

alias v="nvim"
alias vi="nvim"
alias lg="lazygit"

alias ls="eza --group-directories-first"
alias ll="eza -la --group-directories-first --git"
alias la="eza -a --group-directories-first --git"

alias tree="eza --tree"

# History configuration
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt append_history share_history hist_ignore_all_dups hist_ignore_space hist_reduce_blanks

# Smart Directory Navigation
setopt auto_cd auto_pushd pushd_ignore_dups pushd_minus

# Completion & Caching
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.zcompcache"
autoload -Uz compinit
compinit
zstyle ':completion:*' menu select

eval "$(mise activate zsh)"
eval "$(starship init zsh)"
eval "$(fzf --zsh)"

# Setup tab completions
if command -v mise >/dev/null; then
  eval "$(mise completion zsh)"
fi

if command -v chezmoi >/dev/null; then
  eval "$(chezmoi completion zsh)"
fi

if command -v starship >/dev/null; then
  eval "$(starship completions zsh)"
fi

if command -v gh >/dev/null; then
  eval "$(gh completion -s zsh)"
fi


# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/local/mrueve/miniforge3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/local/mrueve/miniforge3/etc/profile.d/conda.sh" ]; then
        . "/local/mrueve/miniforge3/etc/profile.d/conda.sh"
    else
        export PATH="/local/mrueve/miniforge3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

